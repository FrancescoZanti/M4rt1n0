# ==========================================
# AI Sales Assistant - Environment Variables
# ==========================================

# Scegli quale provider utilizzare: "openai", "azure", oppure "local"
LLM_PROVIDER=local

# ------------------------------------------
# Impostazioni per Local LLM (Ollama / vLLM)
# ------------------------------------------
# Per Ollama solitamente la porta è 11434. Assicurati che il modello sia stato scaricato (es: `ollama run llama3`)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3

# ------------------------------------------
# Impostazioni per OpenAI (Cloud)
# ------------------------------------------
OPENAI_API_KEY=sk-tuachiavequi...
OPENAI_MODEL=gpt-4o

# ------------------------------------------
# Impostazioni per Azure OpenAI (Enterprise Cloud)
# ------------------------------------------
AZURE_OPENAI_API_KEY=tuachiave_azure_qui...
AZURE_OPENAI_ENDPOINT=https://tuonome.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-deployment
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ------------------------------------------
# Database Settings (SQL Server) - Prossimo Step
# ------------------------------------------
# DB_SERVER=localhost
# DB_NAME=CeramicSalesDB
# DB_USER=sa
# DB_PASSWORD=SecretPassword123!
